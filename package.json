{
  "name": "chrono-consigliere",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:seed:dealers": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-dealers.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "scrape:run": "ts-node --project tsconfig.scripts.json scripts/run-scrape.ts",
    "scrape:all": "ts-node --project tsconfig.scripts.json scripts/run-all-scrapers.ts",
    "worker": "ts-node --project tsconfig.scripts.json src/lib/queue/worker.ts",
    "scrape:cron": "ts-node --project tsconfig.scripts.json scripts/scrape-direct.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.0.0",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.3.0",
    "ioredis": "^5.3.2",
    "next": "^14.2.35",
    "next-auth": "^4.24.0",
    "playwright": "^1.42.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "0.34.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  }
}
