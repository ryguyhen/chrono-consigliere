// Chrono Consigliere — Prisma Schema
// NOTE: Watches are discovered from external dealer sites.
// Purchases are completed directly on those sites.
// Chrono Consigliere is a discovery and social layer only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?   // null for OAuth-only accounts; required for credentials accounts
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  profile    Profile?
  likes      Like[]
  saves      WishlistItem[]
  purchases  PurchaseEvent[]
  collections Collection[]

  following     Follow[] @relation("follower")
  followers     Follow[] @relation("following")
  feedEvents    ActivityFeedEvent[] @relation("actor")
  receivedEvents ActivityFeedEvent[] @relation("target")

  mobileRefreshTokens MobileRefreshToken[]
  devicePushTokens    DevicePushToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── PROFILE ──────────────────────────────────────────────────────────────────

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  username        String   @unique
  displayName     String?
  bio             String?
  location        String?
  avatarUrl       String?
  wishlistPrivacy Privacy  @default(FRIENDS)
  activityPrivacy Privacy  @default(FRIENDS)

  // Computed taste fields (refreshed by background job)
  tasteTags       String[] // ["Dress Watch", "Sub-36mm", "Manual Wind"]
  topBrands       String[] // ["Patek Philippe", "Rolex"]
  priceRangeMin   Int?
  priceRangeMax   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Privacy {
  PUBLIC
  FRIENDS
  PRIVATE
}

// ─── SOCIAL GRAPH ─────────────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

// ─── DEALER SOURCES ───────────────────────────────────────────────────────────

model DealerSource {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  baseUrl       String
  adapterName   String        // e.g. "CrownCaliberAdapter"
  isActive      Boolean       @default(true)
  scrapeConfig  Json          // adapter-specific config (selectors, pagination, etc)
  lastSyncAt    DateTime?
  listings      WatchListing[]
  scrapeJobs    ScrapeJob[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ─── WATCH LISTINGS ───────────────────────────────────────────────────────────

model WatchListing {
  id            String        @id @default(cuid())
  sourceId      String
  sourceUrl     String        @unique  // original listing URL
  isAvailable   Boolean       @default(true)
  lastCheckedAt DateTime      @default(now())

  // Normalized fields
  brand         String
  model         String
  reference     String?
  year          Int?
  caseSizeMm    Float?
  caseMaterial  String?
  dialColor     String?
  movementType  MovementType?
  condition     Condition?
  style         WatchStyle?
  price         Int?          // in cents
  currency      String        @default("USD")
  description   String?       @db.Text

  // Original dealer fields (preserved as-is)
  sourceTitle   String
  sourcePrice   String?       // e.g. "$24,500" as shown on site

  // Metadata
  likeCount     Int           @default(0)
  saveCount     Int           @default(0)

  source        DealerSource  @relation(fields: [sourceId], references: [id])
  images        WatchImage[]
  likes         Like[]
  saves         WishlistItem[]
  collectionItems CollectionItem[]
  purchases     PurchaseEvent[]
  feedEvents    ActivityFeedEvent[]
  tags          WatchTag[]
  duplicateOf   String?       // points to canonical listing id if dupe

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([brand])
  @@index([style])
  @@index([isAvailable])
  @@index([price])
}

enum MovementType {
  AUTOMATIC
  MANUAL
  QUARTZ
  SPRINGDRIVE
}

enum Condition {
  UNWORN
  MINT
  EXCELLENT
  VERY_GOOD
  GOOD
  FAIR
}

enum WatchStyle {
  DRESS
  SPORT
  DIVE
  CHRONOGRAPH
  FIELD
  GMT
  PILOT
  INTEGRATED_BRACELET
  VINTAGE
  TONNEAU
  SKELETON
}

model WatchImage {
  id         String       @id @default(cuid())
  listingId  String
  url        String
  altText    String?
  isPrimary  Boolean      @default(false)
  width      Int?
  height     Int?
  listing    WatchListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model WatchTag {
  id         String       @id @default(cuid())
  listingId  String
  tag        String
  listing    WatchListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  @@unique([listingId, tag])
}

// ─── SOCIAL ACTIONS ───────────────────────────────────────────────────────────

model Like {
  id        String       @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   WatchListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model WishlistItem {
  id           String       @id @default(cuid())
  userId       String
  listingId    String
  list         WatchList    @default(FAVORITES)
  note         String?
  collectionId String?
  createdAt    DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing      WatchListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  collection   Collection?  @relation(fields: [collectionId], references: [id])

  @@unique([userId, listingId])
}

enum WatchList {
  FAVORITES
  OWNED
}

model PurchaseEvent {
  id             String       @id @default(cuid())
  userId         String
  listingId      String
  purchasedAt    DateTime     @default(now())
  priceActual    Int?         // in cents — self-reported
  notes          String?
  isPublic       Boolean      @default(true)

  // "Influence" tracking — did a friend's curation lead to this?
  influencedByUserId String?

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing        WatchListing @relation(fields: [listingId], references: [id])
}

// ─── COLLECTIONS ──────────────────────────────────────────────────────────────

model Collection {
  id          String           @id @default(cuid())
  userId      String
  name        String           // "Grails", "Under $5k", "Weird But Good"
  description String?
  privacy     Privacy          @default(PUBLIC)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       WishlistItem[]
  collectionItems CollectionItem[]
}

model CollectionItem {
  id           String       @id @default(cuid())
  collectionId String
  listingId    String
  addedAt      DateTime     @default(now())
  note         String?

  collection   Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  listing      WatchListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([collectionId, listingId])
}

// ─── ACTIVITY FEED ────────────────────────────────────────────────────────────

model ActivityFeedEvent {
  id           String    @id @default(cuid())
  actorId      String    // user who performed the action
  targetUserId String?   // user being notified (if different)
  type         FeedEventType
  listingId    String?
  metadata     Json?     // { collectionName, influencedBy, etc }
  createdAt    DateTime  @default(now())

  actor        User         @relation("actor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser   User?        @relation("target", fields: [targetUserId], references: [id])
  listing      WatchListing? @relation(fields: [listingId], references: [id])
}

enum FeedEventType {
  LIKED
  SAVED
  OWNED
  PURCHASED
  INFLUENCED_PURCHASE  // someone bought a watch you liked/saved
  FOLLOWED
  ADDED_TO_COLLECTION
}

// ─── SCRAPING ─────────────────────────────────────────────────────────────────

model ScrapeJob {
  id            String      @id @default(cuid())
  sourceId      String
  status        JobStatus   @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  listingsFound Int?
  listingsNew   Int?
  listingsRemoved Int?
  errorMessage  String?     @db.Text
  logs          ScrapeLog[]

  source        DealerSource @relation(fields: [sourceId], references: [id])
  createdAt     DateTime    @default(now())
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model ScrapeLog {
  id        String   @id @default(cuid())
  jobId     String
  level     LogLevel @default(INFO)
  message   String   @db.Text
  createdAt DateTime @default(now())

  job       ScrapeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

// ─── MOBILE AUTH ──────────────────────────────────────────────────────────────

model MobileRefreshToken {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique   // SHA-256 hash of the opaque refresh token
  deviceLabel  String?            // e.g. "Ryan's iPhone" — for future session management
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DevicePushToken {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique   // Expo push token
  platform     String   @default("ios")  // ios | android
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
